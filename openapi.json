            "description": "Service created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServiceSummary" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/services/{namespace}/{name}": {
