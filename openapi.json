            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/system/info": {
      "get": {
        "summary": "Cluster info",
        "description": "Returns the Kubernetes server version and aggregate counts of nodes, namespaces, and pods.",
        "operationId": "getClusterInfo",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Cluster summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClusterInfo" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/manifests/apply": {
      "post": {
        "summary": "Apply YAML manifests",
        "description": "Accepts raw YAML (single or multi-document separated by ---) and creates each described Kubernetes resource via the dynamic client. Supported kinds: Pod, Service, ConfigMap, ServiceAccount, Namespace, PersistentVolumeClaim, Deployment, StatefulSet, DaemonSet, Job, CronJob, Ingress, Role, RoleBinding, ClusterRole, ClusterRoleBinding.",
        "operationId": "applyManifests",
        "tags": ["Manifests"],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": { "type": "string" },
              "example": "apiVersion: v1\nkind: Pod\nmetadata:\n  name: my-pod\n  namespace: default\nspec:\n  containers:\n  - name: shell\n    image: ubuntu:24.04\n    command: [\"sleep\", \"infinity\"]"
            }
          }
        },
        "responses": {
          "200": {
            "description": "All resources applied successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "applied": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AppliedResource" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "description": "Dynamic client not available" }
        }
      }
    },

    "/manifests/{namespace}/{kind}/{name}": {
      "delete": {
        "summary": "Delete a manifest resource",
        "description": "Deletes a single Kubernetes resource by kind, namespace, and name. Use namespace \"_\" for cluster-scoped resources (ClusterRole, ClusterRoleBinding, Namespace).",
        "operationId": "deleteManifestResource",
        "tags": ["Manifests"],
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "description": "Namespace of the resource, or \"_\" for cluster-scoped resources",
            "schema": { "type": "string", "example": "default" }
          },
          {
            "name": "kind",
            "in": "path",
            "required": true,
            "description": "Kubernetes resource kind (e.g. Pod, Deployment, Service)",
            "schema": { "type": "string", "example": "Pod" }
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Resource name",
            "schema": { "type": "string", "example": "my-pod" }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "description": "Set to true to force immediate deletion (gracePeriod=0)",
            "schema": { "type": "string", "enum": ["true", "false", "1", "0"] }
          }
        ],
        "responses": {
          "204": { "description": "Resource deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "description": "Dynamic client not available" }
        }
      }
    }
  },

  "components": {
    "parameters": {
      "namespace": {
        "name": "namespace",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Kubernetes namespace"
      },
      "name": {
        "name": "name",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Resource name"
      }
    },

    "responses": {
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "BadRequest": {
        "description": "Invalid request body or missing required fields",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalError": {
        "description": "Kubernetes API error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "MetricsUnavailable": {
        "description": "metrics-server is not installed in the cluster",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },

    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "pod not found" }
        }
      },

      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "rolling restart initiated" }
        }
      },

      "CreateExecSessionRequest": {
        "type": "object",
        "properties": {
          "container": {
            "type": "string",
            "description": "Container name (required for multi-container pods)"
          },
          "shell": {
            "type": "string",
            "enum": ["auto", "bash", "sh"],
            "default": "auto",
            "description": "Shell strategy: auto (script then bash then sh), bash (no script), sh (minimal for Alpine/BusyBox)"
          }
        }
      },

      "ExecSessionResponse": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid",
            "description": "Use with GET /pods/exec/ws?sessionId=..."
          }
        }
      },

      "AppliedResource": {
        "type": "object",
        "description": "A Kubernetes resource that was created via ApplyManifests",
        "properties": {
          "kind": { "type": "string", "description": "Kubernetes resource kind", "example": "Pod" },
          "name": { "type": "string", "description": "Resource name", "example": "lab-k8s-shell" },
          "namespace": { "type": "string", "description": "Namespace (omitted for cluster-scoped resources)", "example": "default" }
        }
      },

      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" }
        }
      },

      "ContainerStatus": {
        "type": "object",
        "properties": {
          "name":     { "type": "string" },
          "image":    { "type": "string" },
          "ready":    { "type": "boolean" },
          "restarts": { "type": "integer" },
          "state":    { "type": "string", "example": "running" }
        }
      },

      "PodSummary": {
        "type": "object",
        "properties": {
          "name":       { "type": "string" },
          "namespace":  { "type": "string" },
          "phase":      { "type": "string", "example": "Running" },
          "node_name":  { "type": "string" },
          "pod_ip":     { "type": "string" },
          "start_time": { "type": "string", "format": "date-time" },
          "labels":     { "type": "object", "additionalProperties": { "type": "string" } },
          "containers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContainerStatus" }
          }
        }
      },

      "ContainerMetrics": {
        "type": "object",
        "properties": {
          "name":           { "type": "string" },
          "cpu_millicores": { "type": "integer", "description": "CPU usage in millicores" },
          "memory_mib":     { "type": "integer", "description": "Memory usage in MiB" }
        }
      },

      "PodMetrics": {
        "type": "object",
        "properties": {
          "name":       { "type": "string" },
          "namespace":  { "type": "string" },
          "containers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContainerMetrics" }
          }
        }
      },

      "DeploymentSummary": {
        "type": "object",
        "properties": {
          "name":               { "type": "string" },
          "namespace":          { "type": "string" },
          "replicas":           { "type": "integer" },
          "ready_replicas":     { "type": "integer" },
          "available_replicas": { "type": "integer" },
          "updated_replicas":   { "type": "integer" },
          "image":              { "type": "string" },
          "labels":             { "type": "object", "additionalProperties": { "type": "string" } },
          "created_at":         { "type": "string", "format": "date-time" },
          "conditions":         { "type": "array", "items": { "type": "string" } }
        }
      },

      "EnvVar": {
        "type": "object",
        "properties": {
          "name":  { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["name", "value"]
      },

      "CreateDeploymentRequest": {
        "type": "object",
        "required": ["name", "image"],
        "properties": {
          "name":      { "type": "string", "example": "nginx" },
          "namespace": { "type": "string", "default": "default" },
          "replicas":  { "type": "integer", "default": 1 },
          "image":     { "type": "string", "example": "nginx:latest" },
          "port":      { "type": "integer", "example": 80 },
          "labels":    { "type": "object", "additionalProperties": { "type": "string" } },
          "env": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EnvVar" }
          }
        }
      },

      "ScaleRequest": {
        "type": "object",
        "required": ["replicas"],
        "properties": {
          "replicas": { "type": "integer", "minimum": 0, "example": 3 }
        }
      },

      "ScaleResponse": {
        "type": "object",
        "properties": {
          "name":      { "type": "string" },
          "namespace": { "type": "string" },
          "replicas":  { "type": "integer" }
        }
      },

      "ServicePort": {
        "type": "object",
        "properties": {
          "name":        { "type": "string" },
          "protocol":    { "type": "string", "example": "TCP" },
          "port":        { "type": "integer" },
          "target_port": { "type": "string" },
          "node_port":   { "type": "integer" }
        }
      },

      "ServiceSummary": {
        "type": "object",
        "properties": {
          "name":         { "type": "string" },
          "namespace":    { "type": "string" },
          "type":         { "type": "string", "example": "ClusterIP" },
          "cluster_ip":   { "type": "string" },
          "external_ips": { "type": "array", "items": { "type": "string" } },
          "selector":     { "type": "object", "additionalProperties": { "type": "string" } },
          "labels":       { "type": "object", "additionalProperties": { "type": "string" } },
          "ports":        { "type": "array", "items": { "$ref": "#/components/schemas/ServicePort" } },
          "created_at":   { "type": "string", "format": "date-time" }
        }
      },

      "ServicePortSpec": {
        "type": "object",
        "required": ["port", "target_port"],
        "properties": {
          "name":        { "type": "string" },
          "protocol":    { "type": "string", "enum": ["TCP", "UDP"], "default": "TCP" },
          "port":        { "type": "integer" },
          "target_port": { "type": "integer" },
          "node_port":   { "type": "integer" }
        }
      },

      "CreateServiceRequest": {
        "type": "object",
        "required": ["name", "ports"],
        "properties": {
          "name":      { "type": "string" },
          "namespace": { "type": "string", "default": "default" },
          "type":      { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"], "default": "ClusterIP" },
          "selector":  { "type": "object", "additionalProperties": { "type": "string" } },
          "labels":    { "type": "object", "additionalProperties": { "type": "string" } },
          "ports":     { "type": "array", "items": { "$ref": "#/components/schemas/ServicePortSpec" } }
        }
      },

      "NamespaceSummary": {
        "type": "object",
        "properties": {
          "name":       { "type": "string" },
          "status":     { "type": "string", "example": "Active" },
          "labels":     { "type": "object", "additionalProperties": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },

      "CreateNamespaceRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":   { "type": "string" },
          "labels": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },

      "ConfigMapSummary": {
        "type": "object",
        "properties": {
          "name":       { "type": "string" },
          "namespace":  { "type": "string" },
          "keys":       { "type": "array", "items": { "type": "string" } },
          "labels":     { "type": "object", "additionalProperties": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },

      "CreateConfigMapRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":      { "type": "string" },
          "namespace": { "type": "string", "default": "default" },
          "data":      { "type": "object", "additionalProperties": { "type": "string" } },
          "labels":    { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },

      "PVCSummary": {
        "type": "object",
        "properties": {
          "name":              { "type": "string" },
          "namespace":         { "type": "string" },
          "status":            { "type": "string", "example": "Bound" },
          "storage_class":     { "type": "string" },
          "access_modes":      { "type": "array", "items": { "type": "string" } },
          "capacity":          { "type": "string", "example": "10Gi" },
          "requested_storage": { "type": "string", "example": "10Gi" },
          "volume_name":       { "type": "string" },
          "labels":            { "type": "object", "additionalProperties": { "type": "string" } },
          "created_at":        { "type": "string", "format": "date-time" }
        }
      },

      "CreatePVCRequest": {
        "type": "object",
        "required": ["name", "storage", "access_modes"],
        "properties": {
          "name":          { "type": "string" },
          "namespace":     { "type": "string", "default": "default" },
          "storage_class": { "type": "string" },
          "access_modes":  {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
            },
            "example": ["ReadWriteOnce"]
          },
          "storage": { "type": "string", "example": "10Gi" },
          "labels":  { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },

      "NodeCondition": {
        "type": "object",
        "properties": {
          "type":    { "type": "string" },
          "status":  { "type": "string" },
          "message": { "type": "string" },
          "reason":  { "type": "string" }
        }
      },

      "NodeAddress": {
        "type": "object",
        "properties": {
          "type":    { "type": "string", "example": "InternalIP" },
          "address": { "type": "string", "example": "10.0.0.1" }
        }
      },

      "NodeSummary": {
        "type": "object",
        "properties": {
          "name":               { "type": "string" },
          "status":             { "type": "string", "example": "Ready" },
          "roles":              { "type": "array", "items": { "type": "string" } },
          "kubelet_version":    { "type": "string" },
          "os_image":           { "type": "string" },
          "container_runtime":  { "type": "string" },
          "architecture":       { "type": "string" },
          "cpu_capacity":       { "type": "string" },
          "memory_capacity":    { "type": "string" },
          "cpu_allocatable":    { "type": "string" },
          "memory_allocatable": { "type": "string" },
          "labels":             { "type": "object", "additionalProperties": { "type": "string" } },
          "conditions":         { "type": "array", "items": { "$ref": "#/components/schemas/NodeCondition" } },
          "addresses":          { "type": "array", "items": { "$ref": "#/components/schemas/NodeAddress" } },
          "created_at":         { "type": "string", "format": "date-time" }
        }
      },

      "ClusterInfo": {
        "type": "object",
        "properties": {
          "server_version":   { "type": "string", "example": "v1.32.0" },
          "git_commit":       { "type": "string" },
          "platform":         { "type": "string", "example": "linux/amd64" },
          "go_version":       { "type": "string" },
          "node_count":       { "type": "integer" },
          "namespace_count":  { "type": "integer" },
          "pod_count":        { "type": "integer" }
        }
      }
    }
  },

  "tags": [
    { "name": "Health",                  "description": "Liveness and readiness" },
    { "name": "Pods",                    "description": "Pod lifecycle management" },
    { "name": "Deployments",             "description": "Deployment CRUD, scaling, and rolling restarts" },
    { "name": "Services",                "description": "Service networking management" },
    { "name": "Namespaces",              "description": "Namespace management" },
    { "name": "ConfigMaps",              "description": "ConfigMap management" },
    { "name": "PersistentVolumeClaims",  "description": "PVC storage management" },
    { "name": "Nodes",                   "description": "Node inspection" },
    { "name": "System",                  "description": "Cluster-level information" }
  ]
}
