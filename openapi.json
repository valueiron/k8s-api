{
  "openapi": "3.0.3",
  "info": {
    "title": "Kubernetes REST API",
    "version": "1.1.0",
    "description": "A simplified REST API for managing Kubernetes resources using client-go. Supports pods, deployments, services, namespaces, configmaps, persistent volume claims, nodes, cluster info, and dynamic manifest apply/delete."
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Local development" }
  ],
  "tags": [
    { "name": "Health", "description": "Service liveness" },
    { "name": "Pods", "description": "Pod lifecycle management" },
    { "name": "Deployments", "description": "Deployment management" },
    { "name": "Services", "description": "Service management" },
    { "name": "Namespaces", "description": "Namespace management" },
    { "name": "ConfigMaps", "description": "ConfigMap management" },
    { "name": "PVCs", "description": "PersistentVolumeClaim management" },
    { "name": "Nodes", "description": "Node information" },
    { "name": "System", "description": "Cluster information" },
    { "name": "Manifests", "description": "Dynamic YAML manifest apply and delete for lab provisioning" }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns 200 OK when the server is running. Used for liveness and readiness probes.",
        "operationId": "getHealth",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },

    "/pods": {
      "get": {
        "summary": "List pods",
        "description": "Returns a summary list of all pods. Optionally filter by namespace.",
        "operationId": "listPods",
        "tags": ["Pods"],
        "parameters": [
          {
            "name": "namespace",
            "in": "query",
            "description": "Filter by namespace. Omit to list across all namespaces.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pod summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PodSummary" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/pods/{namespace}/{name}": {
      "get": {
        "summary": "Inspect a pod",
        "description": "Returns full Kubernetes Pod object.",
        "operationId": "getPod",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" }
        ],
        "responses": {
          "200": {
            "description": "Pod object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PodSummary" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "delete": {
        "summary": "Delete a pod",
        "description": "Deletes a pod. If managed by a controller the pod will be recreated. Pass ?force=true to set gracePeriodSeconds=0.",
        "operationId": "deletePod",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" },
          {
            "name": "force",
            "in": "query",
            "description": "Set to 'true' or '1' to delete with grace period 0.",
            "schema": { "type": "string", "enum": ["true", "1"] }
          }
        ],
        "responses": {
          "204": { "description": "Pod deleted" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/pods/{namespace}/{name}/logs": {
      "get": {
        "summary": "Get pod logs",
        "description": "Streams the log output of a pod container as plain text.",
        "operationId": "getPodLogs",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" },
          {
            "name": "container",
            "in": "query",
            "description": "Container name (required for multi-container pods).",
            "schema": { "type": "string" }
          },
          {
            "name": "tail",
            "in": "query",
            "description": "Number of lines to return from the end of the log (default 100).",
            "schema": { "type": "integer", "default": 100 }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Only return logs after this RFC3339 timestamp.",
            "schema": { "type": "string", "format": "date-time" }
          }
        ],
        "responses": {
          "200": {
            "description": "Log output",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/pods/{namespace}/{name}/metrics": {
      "get": {
        "summary": "Get pod metrics",
        "description": "Returns CPU (millicores) and memory (MiB) usage for each container. Requires metrics-server to be installed.",
        "operationId": "getPodMetrics",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" }
        ],
        "responses": {
          "200": {
            "description": "Pod metrics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PodMetrics" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/MetricsUnavailable" }
        }
      }
    },

    "/pods/{namespace}/{name}/restart": {
      "post": {
        "summary": "Restart a pod",
        "description": "Deletes the pod so its controller (e.g. Deployment) recreates it.",
        "operationId": "restartPod",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" }
        ],
        "responses": {
          "200": {
            "description": "Pod deleted, will be recreated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/pods/{namespace}/{name}/exec": {
      "post": {
        "summary": "Create pod exec session",
        "description": "Creates a session for an interactive shell in the pod. Returns a sessionId to use with the exec WebSocket endpoint. Optional body: container (for multi-container pods) and shell (\"auto\", \"bash\", or \"sh\"). Default shell \"auto\" tries script+PTY then bash then sh; \"bash\" skips script; \"sh\" is minimal for Alpine/BusyBox.",
        "operationId": "createPodExecSession",
        "tags": ["Pods"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          { "$ref": "#/components/parameters/name" }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateExecSessionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExecSessionResponse" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },

    "/pods/exec/ws": {
      "get": {
        "summary": "Pod exec WebSocket",
        "description": "Upgrades to WebSocket for interactive shell I/O. Query param: sessionId (from POST /pods/{namespace}/{name}/exec). Client sends: binary/text → stdin; JSON { \"type\": \"resize\", \"cols\", \"rows\" }; { \"type\": \"ping\" }. Server sends: binary → stdout/stderr; JSON { \"type\": \"connected\" }, { \"type\": \"disconnected\" }, { \"type\": \"error\", \"message\" }, { \"type\": \"pong\" }.",
        "operationId": "podExecWebSocket",
        "tags": ["Pods"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Session ID from createPodExecSession"
          }
        ],
        "responses": {
          "101": { "description": "Switching Protocols (WebSocket upgrade)" },
          "400": { "description": "Missing or invalid sessionId" },
          "404": { "description": "Session not found or expired" }
        }
      }
    },

    "/deployments": {
      "get": {
        "summary": "List deployments",
        "description": "Returns all deployments, optionally filtered by namespace.",
        "operationId": "listDeployments",
        "tags": ["Deployments"],
        "parameters": [
          {
            "name": "namespace",
            "in": "query",
            "description": "Filter by namespace.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of deployment summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DeploymentSummary" }
